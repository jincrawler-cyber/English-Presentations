        // --- SISTEMA ANTI-TRAMPAS ---
        function startAntiCheat() { 
            if (state.focusListenerAdded || state.studentKey === 'Test1973') return; 
            
            const triggerPenalty = (reason) => {
                if (state.view !== 'quiz' || state.isAnswered) return;
                playAlarm(); state.warnings++; 
                const q = state.quizData[state.qIndex];
                state.detailedAnswers[q.id] = { type: 'cheat', val: 'ANULADA: ' + reason, correct: false };
                state.isAnswered = true; 
                
                document.getElementById('cheat-reason').innerText = "Motivo: " + reason;
                document.getElementById('cheat-overlay').style.display = 'block';
                saveState(); 
            };

            window.addEventListener('blur', () => triggerPenalty("Cambio de ventana / Uso de otra App"));
            document.addEventListener("visibilitychange", () => { if (document.hidden) triggerPenalty("Pestaña ocultada"); });
            document.addEventListener('keyup', (e) => {
                if (e.key === 'PrintScreen' || e.code === 'PrintScreen' || (e.shiftKey && (e.metaKey || e.key === 'Meta'))) {
                    triggerPenalty("Intento de Captura/Recorte de Pantalla");
                }
            });
            document.addEventListener('copy', (e) => { e.preventDefault(); if (e.clipboardData) e.clipboardData.setData('text/plain', 'COPIA DENEGADA'); });
            window.addEventListener('beforeunload', (e) => {
                if (state.view === 'quiz' && !state.isAnswered) {
                    state.warnings++; saveState(); // Guarda que intentó recargar
                }
            });

            state.focusListenerAdded = true; 
        }

        window.dismissCheat = () => { document.getElementById('cheat-overlay').style.display = 'none'; window.next(); };

        // --- GESTIÓN DE BD ---
        async function verifyStudentKey(key) { 
            if (key === 'Test1973') return "Usuario de Prueba";
            if (state.mode === 'local') {
                const localKeys = JSON.parse(localStorage.getItem('quiz_keys_local') || '{}');
                if (localKeys[key.toUpperCase()]) return localKeys[key.toUpperCase()].nombre;
                return null;
            }
            try { const d = await getDoc(getDocRef('claves_alumnos', key.toUpperCase())); return d.exists() ? d.data().nombre : null; } catch(e) { return null; } 
        }

        async function createStudentKey(key, name) { 
            if (state.mode === 'cloud') { await setDoc(getDocRef('claves_alumnos', key.toUpperCase()), { nombre: name }); }
            else { const localKeys = JSON.parse(localStorage.getItem('quiz_keys_local') || '{}'); localKeys[key.toUpperCase()] = { nombre: name }; localStorage.setItem('quiz_keys_local', JSON.stringify(localKeys)); startAdmin(); }
        }

        async function deleteStudentKey(key) { 
            if (state.mode === 'cloud') { await deleteDoc(getDocRef('claves_alumnos', key)); }
            else { const localKeys = JSON.parse(localStorage.getItem('quiz_keys_local') || '{}'); delete localKeys[key]; localStorage.setItem('quiz_keys_local', JSON.stringify(localKeys)); startAdmin(); }
        }

        function listenToData(name, cb) { if (state.mode === 'cloud') onSnapshot(query(getColRef(name)), (s) => cb(s.docs.map(d => ({ id: d.id, ...d.data() })))); }

        function initQuestionData(q) {
            state.isAnswered = false; state.selectedGroupingItem = null;
            if (q.type === 'choice' || q.type === 'reading' || q.type === 'listening') state.tempAnswer = null;
            else if (q.type === 'text' || q.type === 'essay') state.tempAnswer = '';
            else if (q.type === 'matching') { const indices = q.pairs.map((_, i) => i); state.tempAnswer = { leftSelected: null, matches: {}, shuffledRight: shuffle([...indices]) }; }
            else if (q.type === 'order') { state.tempAnswer = { pool: shuffle(q.items.map((item, i) => ({ id: i, text: item }))), answer: [] }; }
            else if (q.type === 'fill-gap') { const regex = /{([^}]+)}/g; let parts = [], correctAnswers = [], match, lastIndex = 0; while ((match = regex.exec(q.text)) !== null) { parts.push(q.text.substring(lastIndex, match.index)); correctAnswers.push(match[1]); lastIndex = regex.lastIndex; } parts.push(q.text.substring(lastIndex)); state.tempAnswer = { userInputs: Array(correctAnswers.length).fill(''), parts, correctAnswers }; }
            else if (q.type === 'grouping') { state.tempAnswer = shuffle(q.items.map((item, i) => ({ ...item, originalIdx: i, currentGroup: null }))); }
        }

