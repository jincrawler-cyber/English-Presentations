        // --- HELPERS BÁSICOS ---
        const getColRef = (name) => collection(state.db, 'artifacts', state.appId, 'public', 'data', name);
        const getDocRef = (colName, docId) => doc(state.db, 'artifacts', state.appId, 'public', 'data', colName, docId);
        
        function shuffle(array) { return array.sort(() => Math.random() - 0.5); }
        function normalizeText(text) { 
            if (!text) return "";
            return text.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim(); 
        }

        const playAlarm = () => {
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator(); const gain = ctx.createGain();
                osc.connect(gain); gain.connect(ctx.destination);
                osc.type = 'sawtooth'; osc.frequency.setValueAtTime(440, ctx.currentTime);
                gain.gain.setValueAtTime(0.5, ctx.currentTime); gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 1);
                osc.start(); osc.stop(ctx.currentTime + 1);
            } catch(e) {}
        };

        // --- SISTEMA DE GUARDADO LOCAL (PERSISTENCIA) ---
        function saveState() {
            if (state.studentKey && state.studentKey !== 'Test1973') {
                const savedData = {
                    studentName: state.studentName, qIndex: state.qIndex, score: state.score,
                    warnings: state.warnings, detailedAnswers: state.detailedAnswers,
                    quizOrder: state.quizData.map(q => q.id), finished: state.view === 'finished',
                    timestamp: new Date().toISOString()
                };
                localStorage.setItem(`quiz_state_${state.studentKey.toUpperCase()}`, JSON.stringify(savedData));
            }
        }

        function restoreState(key) {
            const saved = localStorage.getItem(`quiz_state_${key.toUpperCase()}`);
            if (saved) {
                const data = JSON.parse(saved);
                state.studentName = data.studentName || state.studentName;
                if (data.finished) {
                    state.score = data.score; state.warnings = data.warnings;
                    state.detailedAnswers = data.detailedAnswers; state.quizData = restoreOrder(data.quizOrder); 
                    state.view = 'finished'; return true;
                } else {
                    state.qIndex = data.qIndex; state.score = data.score; state.warnings = data.warnings;
                    state.detailedAnswers = data.detailedAnswers; state.quizData = restoreOrder(data.quizOrder);
                    return false; 
                }
            }
            return null; 
        }

        function restoreOrder(orderIds) {
            let ordered = [];
            orderIds.forEach(id => { const q = RAW_QUIZ_DATA.find(x => x.id === id); if (q) ordered.push(q); });
