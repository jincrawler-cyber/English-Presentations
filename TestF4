        window.grpClickGroup = (gIdx) => { if(state.isAnswered || state.selectedGroupingItem === null) return; state.tempAnswer[state.selectedGroupingItem].currentGroup = gIdx; state.selectedGroupingItem = null; render(); };
        window.ansChoice = (idx) => { state.tempAnswer = idx; state.isAnswered = true; window.check(); };
        window.matchLeft = (i) => { if(state.isAnswered) return; state.tempAnswer.leftSelected = i; render(); };
        window.matchRight = (i) => { if(state.isAnswered || state.tempAnswer.leftSelected===null) return; state.tempAnswer.matches[state.tempAnswer.leftSelected] = i; state.tempAnswer.leftSelected = null; render(); };
        window.moveOrder = (i, dir) => { if(state.isAnswered) return; const {pool,answer} = state.tempAnswer; if(dir==='to') answer.push(pool.splice(i,1)[0]); else pool.push(answer.splice(i,1)[0]); render(); };

        // --- VERIFICACIÓN DE RESPUESTAS ---
        window.check = () => {
            const q = state.quizData[state.qIndex]; 
            state.isAnswered = true; 
            let isCorrect = false;
            
            if (q.type === 'text') isCorrect = normalizeText(state.tempAnswer) === normalizeText(q.correct);
            else if (q.type === 'matching') isCorrect = Object.entries(state.tempAnswer.matches).every(([l,r]) => parseInt(l) === parseInt(r));
            else if (q.type === 'order') isCorrect = state.tempAnswer.answer.map(a => a.text).join(' ') === q.items.join(' ');
            else if (q.type === 'fill-gap') isCorrect = state.tempAnswer.userInputs.every((v,i) => normalizeText(v) === normalizeText(state.tempAnswer.correctAnswers[i]));
            else if (q.type === 'grouping') isCorrect = state.tempAnswer.every(i => i.currentGroup === i.group);
            else if (q.type === 'choice' || q.type === 'reading' || q.type === 'listening') isCorrect = state.tempAnswer === q.correct;
            else if (q.type === 'essay') { 
                const t = normalizeText(state.tempAnswer);
                const w = t.split(" ").length;
                const k = q.keywords.filter(k => t.includes(normalizeText(k))).length; 
                isCorrect = w >= (q.minWords || 5) && k >= (q.keywords.length / 2); 
            }
            
            if (isCorrect) state.score++;
            
            state.detailedAnswers[q.id] = { type: q.type, val: state.tempAnswer, correct: isCorrect };
            saveState(); 
            
            const btn = document.getElementById('submit-btn'); 
            if(btn) { btn.innerText = "Guardado ✓"; btn.classList.add('bg-green-600', 'text-white'); btn.classList.remove('bg-indigo-600'); } 
            setTimeout(() => { window.next(); }, 600);
        };

        window.next = () => { 
            if (state.qIndex + 1 < state.quizData.length) { 
                const currType = state.quizData[state.qIndex].type;
                const nextType = state.quizData[state.qIndex + 1].type;
                
                state.qIndex++; 
                initQuestionData(state.quizData[state.qIndex]); 
                saveState(); 
                
                // Activar sala de espera solo al transicionar hacia el bloque de listening
                if (currType !== 'listening' && nextType === 'listening') {
                    state.view = 'waiting_listening';
                } else {
                    state.view = 'quiz'; 
                }
                render(); 
            } else { finishQuiz(); } 
        };

        // --- PANTALLA FINAL ---
        async function finishQuiz() { 
            state.view = 'finished'; render(); saveState(); 
            const n = ((state.score / state.quizData.length) * 10).toFixed(1); 
            if (state.mode === 'cloud') { 
                try { 
                    await addDoc(getColRef('resultados_quiz'), { 
                        studentName: state.studentName, studentKey: state.studentKey, 
                        score: state.score, grade10: n, totalQuestions: state.quizData.length, 
                        timestamp: new Date().toISOString(), warnings: state.warnings, 
                        answers: JSON.stringify(state.detailedAnswers) 
                    }); 
                } catch(e) {} 
            } 
        }

        function renderFinished(c) { 
            const n = ((state.score / state.quizData.length) * 10).toFixed(1); 
            c.innerHTML = `
                <div class="bg-white p-10 rounded-3xl shadow-2xl text-center fade-in max-w-md w-full prevent-select border-t-8 border-indigo-500">
                    <i class="ph ph-check-circle text-green-500 text-6xl mb-2"></i>
                    <h2 class="text-3xl font-bold mb-2 text-slate-800">¡Examen Finalizado!</h2>
                    <p class="text-slate-500 mb-8 font-medium">Gracias ${state.studentName}.</p>
                    <div class="bg-slate-50 p-6 rounded-2xl mb-8 border border-slate-100">
                        <div class="text-sm text-slate-400 mb-1 uppercase tracking-widest font-bold">Nota Final</div>
                        <div class="text-6xl font-black text-indigo-600">${n}</div>
                    </div>
                    <button onclick="location.reload()" class="bg-slate-800 text-white px-6 py-4 rounded-xl w-full shadow-lg hover:bg-slate-900 transition font-bold uppercase tracking-wide">Salir del Sistema</button>
                </div>`; 
        }

        // --- DASHBOARD DE ADMINISTRADOR ---
        function renderAdminLogin(c) { 
            c.innerHTML = `
                <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-sm text-center fade-in">
                    <h2 class="text-xl font-bold mb-4 flex items-center justify-center gap-2"><i class="ph ph-chalkboard-teacher text-indigo-600"></i> Portal Profesor</h2>
                    <div id="admin-err" class="hidden bg-red-100 text-red-600 p-2 rounded mb-4 text-sm font-bold">Contraseña incorrecta</div>
                    <input type="password" id="ap" placeholder="Contraseña Admin" class="w-full p-4 border-2 rounded-xl mb-4 text-center focus:border-indigo-500 outline-none">
                    <button id="abl" class="bg-slate-800 text-white w-full py-4 rounded-xl font-bold shadow hover:bg-slate-700 transition">Entrar</button>
                    <button onclick="location.reload()" class="mt-6 text-xs text-slate-400 font-bold uppercase hover:text-slate-600 transition">Volver al inicio</button>
                </div>`; 
            const attemptLogin = () => { const val = document.getElementById('ap').value; if (val === PASSWORD_ADMIN) { state.view = 'admin_dashboard'; startAdmin(); render(); } else { document.getElementById('admin-err').classList.remove('hidden'); } };
            document.getElementById('abl').onclick = attemptLogin;
            document.getElementById('ap').onkeydown = (e) => { if(e.key === 'Enter') attemptLogin(); };
        }
        
        function startAdmin() { 
            if (state.mode === 'cloud') {
                listenToData('resultados_quiz', d => { state.results = d.sort((a,b) => b.score - a.score); if(state.view === 'admin_dashboard') render(); }); 
                listenToData('claves_alumnos', d => { state.studentsList = d.sort((a,b) => a.nombre.localeCompare(b.nombre)); if(state.view === 'admin_dashboard') render(); }); 
            } else {
                const localResults = [];
                for (let i = 0; i < localStorage.length; i++) {
                    const key = localStorage.key(i);
                    if (key.startsWith('quiz_state_')) {
                        try {
                            const data = JSON.parse(localStorage.getItem(key));
                            if (data.studentName && (data.finished || data.score > 0)) {
                                localResults.push({ id: key, studentName: data.studentName, studentKey: key.replace('quiz_state_', ''), score: data.score, grade10: ((data.score / (data.quizOrder ? data.quizOrder.length : 1)) * 10).toFixed(1), totalQuestions: data.quizOrder ? data.quizOrder.length : 0, warnings: data.warnings || 0, timestamp: data.timestamp || new Date().toISOString(), answers: JSON.stringify(data.detailedAnswers || {}) });
                            }
                        } catch(e) {}
                    }
                }
                state.results = localResults.sort((a,b) => b.score - a.score);
                const localKeysObj = JSON.parse(localStorage.getItem('quiz_keys_local') || '{}');
                state.studentsList = Object.keys(localKeysObj).map(k => ({ id: k, nombre: localKeysObj[k].nombre })).sort((a,b) => a.nombre.localeCompare(b.nombre));
                if(state.view === 'admin_dashboard') render();
            }
        }

function renderAdminDashboard(c) {
            const rows = state.adminTab === 'results' ? state.results.map((r, i) => { const g = r.grade10 || ((r.score/r.totalQuestions)*10).toFixed(1); return `<tr class="border-b text-sm hover:bg-slate-50"><td class="p-3">${i+1}</td><td class="p-3 font-medium">${r.studentName}</td><td class="p-3 font-bold text-lg text-indigo-600">${g}</td><td class="p-3 text-center">${r.warnings>0?'<span class="text-red-600 bg-red-100 px-2 py-1 rounded font-bold">⚠️ '+r.warnings+'</span>':''}</td><td class="p-3 text-right"><button onclick="window.openReview('${r.id}')" class="bg-blue-100 text-blue-600 p-2 rounded hover:bg-blue-200 mr-2 transition"><i class="ph ph-eye"></i></button><button onclick="window.delRes('${r.id}', this)" class="bg-red-50 text-red-500 p-2 rounded hover:bg-red-100 transition"><i class="ph ph-trash"></i></button></td></tr>`; }).join('') : state.studentsList.map(s => `<tr class="border-b text-sm"><td class="p-3 font-bold text-indigo-600">${s.id}</td><td class="p-3">${s.nombre}</td><td class="p-3 text-right"><button onclick="window.delKey('${s.id}', this)" class="bg-red-50 text-red-500 p-2 rounded hover:bg-red-100"><i class="ph ph-trash"></i></button></td></tr>`).join('');
            
            // ---> AQUÍ SE AÑADIÓ EL CÓDIGO HTML PARA SUBIR EL CSV EN LA PESTAÑA "KEYS" <---
            const content = state.adminTab === 'results' 
                ? `<div class="flex justify-end mb-2"><button onclick="window.exportCSV()" class="bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 hover:bg-green-700 transition shadow-md"><i class="ph ph-file-csv text-lg"></i> Exportar a Excel</button></div><table class="w-full text-left bg-white rounded-xl shadow-sm text-sm overflow-hidden border border-slate-200"><thead class="bg-slate-50 border-b border-slate-200"><tr><th class="p-3 text-slate-500 font-bold uppercase tracking-wider text-xs">#</th><th class="p-3 text-slate-500 font-bold uppercase tracking-wider text-xs">Alumno</th><th class="p-3 text-slate-500 font-bold uppercase tracking-wider text-xs">Nota</th><th class="p-3 text-center text-slate-500 font-bold uppercase tracking-wider text-xs">Alertas</th><th class="p-3"></th></tr></thead><tbody>${rows||'<tr><td colspan="5" class="p-8 text-center text-slate-400 italic">No hay exámenes registrados aún</td></tr>'}</tbody></table>` 
                : `<div class="mb-4 bg-white p-4 rounded-xl shadow-sm border border-slate-100 flex flex-col gap-4">
                    <div class="flex gap-2">
                        <input id="nk" placeholder="Clave (Ej: JUAN01)" class="p-3 border border-slate-200 rounded-lg w-1/3 outline-none focus:border-indigo-400 uppercase">
                        <input id="nn" placeholder="Nombre Completo" class="p-3 border border-slate-200 rounded-lg w-1/2 outline-none focus:border-indigo-400">
                        <button onclick="window.addKey()" class="bg-indigo-600 text-white px-6 font-bold rounded-lg hover:bg-indigo-700 transition">Agregar Manual</button>
                    </div>
                    <div class="border-t border-slate-100 pt-4 flex justify-between items-center">
                        <span class="text-xs text-slate-500 font-bold uppercase tracking-widest">O Importar desde Excel (.CSV):</span>
                        <div class="flex gap-2 items-center">
                            <input type="file" id="csvFileInput" accept=".csv" class="text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 cursor-pointer">
                            <button onclick="window.importStudentCSV()" class="bg-green-600 text-white px-4 py-2 font-bold rounded-lg hover:bg-green-700 transition shadow-sm flex items-center gap-2"><i class="ph ph-upload-simple"></i> Cargar</button>
                        </div>
                    </div>
                   </div>
                   <table class="w-full text-left bg-white rounded shadow text-sm border border-slate-200"><thead class="bg-slate-50 border-b"><tr><th class="p-3 text-slate-500 font-bold uppercase tracking-wider text-xs">Clave</th><th class="p-3 text-slate-500 font-bold uppercase tracking-wider text-xs">Nombre</th><th></th></tr></thead><tbody>${rows}</tbody></table>`;
            
            c.innerHTML = `<div class="w-full max-w-4xl fade-in self-start mt-8"><div class="flex justify-between items-center mb-6"><h2 class="text-2xl font-bold flex items-center gap-2 text-slate-800"><i class="ph ph-chalkboard-teacher text-indigo-600"></i> Panel de Control</h2><button onclick="location.reload()" class="text-sm text-red-600 bg-red-50 px-4 py-2 rounded-lg font-bold hover:bg-red-100 transition shadow-sm border border-red-100">Cerrar Sesión</button></div><div class="flex gap-2 mb-4 bg-slate-200 p-1 rounded-xl inline-flex shadow-inner"><button onclick="window.setTab('results')" class="px-6 py-2 rounded-lg text-sm font-bold transition ${state.adminTab==='results'?'bg-white shadow text-indigo-600':'text-slate-500 hover:text-slate-700'}">Exámenes Completados</button><button onclick="window.setTab('keys')" class="flex-1 py-2 rounded-lg text-sm font-bold transition ${state.adminTab==='keys'?'bg-white shadow text-indigo-600':'text-slate-500 hover:text-slate-700'}">Base de Alumnos (Claves)</button></div>${content}</div>`;
            window.setTab = t => { state.adminTab = t; render(); }; 
            window.exportCSV = () => { let csv = "Nombre,Clave,Nota (Base 10),Puntos,Alertas de Trampa,Fecha y Hora\n"; state.results.forEach(r => { const dateObj = new Date(r.timestamp); const formattedDate = isNaN(dateObj) ? r.timestamp : dateObj.toLocaleString(); csv += `"${r.studentName}","${r.studentKey}",${r.grade10},${r.score},${r.warnings},"${formattedDate}"\n`; }); const blob = new Blob([new Uint8Array([0xEF, 0xBB, 0xBF]), csv], { type: 'text/csv;charset=utf-8;' }); const link = document.createElement("a"); link.href = URL.createObjectURL(blob); link.download = "Resultados_Examen.csv"; link.click(); };
            window.delRes = async (id, btn) => { if (btn.dataset.confirm !== 'true') { btn.dataset.confirm = 'true'; btn.innerHTML = '¿Seguro?'; btn.classList.add('bg-red-600', 'text-white'); setTimeout(() => { btn.dataset.confirm = 'false'; btn.innerHTML = '<i class="ph ph-trash"></i>'; btn.classList.remove('bg-red-600', 'text-white'); }, 3000); return; } if (state.mode === 'cloud') { await deleteDoc(getDocRef('resultados_quiz', id)); } else { localStorage.removeItem(id); startAdmin(); } }; 
            window.delKey = async (id, btn) => { if (btn.dataset.confirm !== 'true') { btn.dataset.confirm = 'true'; btn.innerHTML = '¿Seguro?'; btn.classList.add('bg-red-600', 'text-white'); setTimeout(() => { btn.dataset.confirm = 'false'; btn.innerHTML = '<i class="ph ph-trash"></i>'; btn.classList.remove('bg-red-600', 'text-white'); }, 3000); return; } await deleteStudentKey(id); }; 
            window.addKey = async () => { const k=document.getElementById('nk').value.toUpperCase(), n=document.getElementById('nn').value; if(k&&n) { await createStudentKey(k,n); document.getElementById('nk').value=''; document.getElementById('nn').value=''; } };
            
            // ---> AQUÍ SE AÑADIÓ LA LÓGICA JAVASCRIPT PARA LEER EL CSV <---
            window.importStudentCSV = () => {
                const fileInput = document.getElementById('csvFileInput');
                const file = fileInput.files[0];
                if (!file) { 
                    alert("Por favor, selecciona un archivo .csv primero."); 
                    return; 
                }

                const reader = new FileReader();
                reader.onload = async (e) => {
                    const text = e.target.result;
                    const rows = text.split('\n');
                    let count = 0;
                    
                    for (let i = 0; i < rows.length; i++) {
                        const row = rows[i].trim();
                        if (!row) continue;
                        
                        const cols = row.split(',');
                        if (cols.length >= 2) {
                            const key = cols[0].trim().toUpperCase();
                            const name = cols[1].trim();
                            
                            // Ignora si la primera fila es un encabezado que dice "Clave" y "Nombre"
                            if (key.toLowerCase() === 'clave' || name.toLowerCase() === 'nombre') continue;
                            
                            if (key && name) {
                                await createStudentKey(key, name);
                                count++;
                            }
                        }
                    }
                    alert(`¡Se importaron ${count} alumnos exitosamente!`);
                    fileInput.value = '';
                    if (state.mode === 'local') startAdmin(); // Refresca los cambios si usas local
                };
                reader.readAsText(file);
            };

            window.openReview = (id) => { 
                const r = state.results.find(x => x.id === id); if(!r) return; let ans = {}; try { ans = JSON.parse(r.answers || '{}'); } catch(e){} 
                let h = `<div class="mb-6 bg-indigo-50 border border-indigo-100 p-6 rounded-xl flex justify-between items-center shadow-sm"><div><h4 class="font-black text-2xl text-indigo-900">${r.studentName}</h4><span class="text-indigo-500 font-mono text-sm mt-1 block">Clave: ${r.studentKey}</span></div><div class="text-right bg-white p-3 rounded-xl shadow-sm border border-indigo-50"><p class="text-xs text-indigo-400 font-bold uppercase tracking-wider mb-1">Nota Actual</p><p class="font-black text-4xl text-indigo-600 leading-none">${r.grade10}</p></div></div>`; 
                let storedQuizData = [];
                try {
                     if (state.mode === 'local') {
                         storedQuizData = JSON.parse(localStorage.getItem(r.id)).quizOrder.map(id => RAW_QUIZ_DATA.find(q => q.id === id));
                     } else {
                         storedQuizData = RAW_QUIZ_DATA; 
                     }
                } catch(e) { storedQuizData = RAW_QUIZ_DATA; }

                storedQuizData.forEach((q, i) => { 
                    if(!q) return;
                    const a = ans[q.id]; let s = "El alumno no respondió esta pregunta o cerró la página.", c = false; 
                    if (a) { 
                        c = a.correct; 
                        if(a.type==='cheat') s=`<span class="text-red-600 font-bold"><i class="ph ph-warning"></i> ${a.val}</span>`; 
                        else if (q.type === 'choice' || q.type === 'reading' || q.type==='listening') s = q.options[a.val] || "Opción inválida"; 
                        else if (q.type === 'essay' || q.type === 'text') s = a.val; 
                        else if (q.type === 'fill-gap') s = `Respuestas del alumno: ${a.val.userInputs.join(' | ')}`; 
                        else s = "[Actividad Interactiva Completada]"; 
                    } 
                    h += `<div class="mb-4 border-b border-slate-100 pb-5"><div class="flex justify-between items-center mb-2"><p class="font-bold text-xs text-slate-400 uppercase tracking-wider">Pregunta ${i+1} <span class="lowercase bg-slate-100 px-2 py-0.5 rounded text-slate-500 ml-1">${q.type}</span></p>${c?'<span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold border border-green-200">CORRECTO</span>':'<span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-bold border border-red-200">INCORRECTO</span>'}</div><p class="mb-3 font-medium text-slate-800 text-base">${q.q}</p><div class="bg-slate-50 p-4 rounded-lg text-sm font-mono border-l-4 ${c?'border-green-400 text-slate-700':'border-red-400 text-red-700'} whitespace-pre-wrap">${s}</div></div>`; 
                }); 
                h += `<div class="mt-6 pt-6 border-t-2 border-slate-200 bg-slate-50 p-6 rounded-xl"><label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide"><i class="ph ph-pencil-simple text-indigo-600"></i> Modificar Calificación Manualmente</label><p class="text-xs text-slate-500 mb-4">Si consideras que un ensayo o texto corto estaba correcto, puedes cambiar la nota final (Base 10) aquí.</p><div class="flex gap-3 items-center"><input type="number" id="new-grade" value="${r.grade10}" step="0.1" max="10" min="0" class="border-2 border-slate-300 p-3 rounded-xl w-32 text-2xl font-bold text-center focus:border-indigo-500 outline-none"><button onclick="window.updateGrade('${r.id}')" class="bg-indigo-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-indigo-700 shadow-md transition">Actualizar Nota</button></div></div>`;
                document.getElementById('review-content').innerHTML = h; document.getElementById('review-modal').style.display = 'flex'; 
            }; 

            window.updateGrade = async (id) => {
                const newGrade = document.getElementById('new-grade').value;
                if(newGrade) {
                    if(state.mode === 'cloud') {
                        await updateDoc(getDocRef('resultados_quiz', id), { grade10: newGrade });
                    } else {
                        const localData = JSON.parse(localStorage.getItem(id));
                        if(localData) {
                            localData.grade10 = newGrade;
                            localStorage.setItem(id, JSON.stringify(localData));
                            startAdmin();
                        }
                    }
                    document.getElementById('review-modal').style.display='none';
                }
            };
        }

        init();
    </script>
</body>
</html>
