    <style>
        /* Estilos Base y Anti-Copia Móvil */
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background-color: #f3f4f6; 
            color: #1f2937; 
            -webkit-touch-callout: none; 
        }
        .prevent-select { -webkit-user-select: none; user-select: none; }
        .prevent-select input, .prevent-select textarea { -webkit-user-select: text !important; user-select: text !important; }
        .fade-in { animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Interacciones y Grupos */
        .match-item, .order-tag, .group-item { transition: all 0.2s; cursor: pointer; touch-action: manipulation; }
        .match-item img { max-width: 100px; max-height: 100px; object-fit: contain; display: block; margin: 0 auto; border-radius: 4px; pointer-events: none; }
        .match-item { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; min-height: 60px; }
        .match-selected { background-color: #e0e7ff; border-color: #6366f1; transform: scale(1.02); box-shadow: 0 4px 6px -1px rgba(99, 102, 241, 0.2); }
        .group-item-selected { background-color: #4f46e5; color: white; border-color: #4338ca; transform: scale(1.05); box-shadow: 0 4px 6px rgba(0,0,0,0.15); z-index: 50; }
        .group-target { transition: all 0.2s; border: 2px dashed #cbd5e1; }
        .group-target:active { background-color: #f1f5f9; border-color: #94a3b8; }
        
        /* Lectura y Escucha */
        .reading-text { max-height: 200px; overflow-y: auto; background: #fffbeb; border-left: 4px solid #f59e0b; padding: 1rem; margin-bottom: 1.5rem; font-style: italic; color: #4b5563; font-size: 0.95rem; line-height: 1.6; }
        .listening-banner { background: #eff6ff; border: 2px solid #bfdbfe; padding: 1rem; border-radius: 0.75rem; text-align: center; margin-bottom: 1.5rem; color: #1e40af; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
        
        /* Modales y Alertas */
        #cheat-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(220, 38, 38, 0.98); z-index: 9999; color: white; text-align: center; padding-top: 25vh; backdrop-filter: blur(10px); }
        #review-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 40; align-items: center; justify-content: center; }
        #penalty-toast { display: none; position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #991b1b; color: white; padding: 15px 25px; border-radius: 50px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 200; font-weight: bold; animation: slideUp 0.3s ease-out; }
        @keyframes slideUp { from { transform: translate(-50%, 100%); opacity: 0; } to { transform: translate(-50%, 0); opacity: 1; } }
        
        @media print { body { display: none !important; } }
    </style>
