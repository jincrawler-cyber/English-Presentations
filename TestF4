        // --- INICIALIZACIÓN ---
        async function init() {
            try {
                if (typeof __app_id !== 'undefined') state.appId = __app_id;
                let c = MI_CONFIGURACION_FIREBASE;
                if (!c && typeof __firebase_config !== 'undefined') c = JSON.parse(__firebase_config);
                if (c) { initFirebase(c); } else { state.view = 'setup'; render(); }
            } catch (e) { state.view = 'setup'; render(); }
        }

        async function initFirebase(config) {
            try {
                const app = initializeApp(config);
                state.auth = getAuth(app); state.db = getFirestore(app);
                
                const authPromise = (typeof __initial_auth_token !== 'undefined' && __initial_auth_token && !MI_CONFIGURACION_FIREBASE)
                    ? signInWithCustomToken(state.auth, __initial_auth_token)
                    : signInAnonymously(state.auth);
                
                const timeoutPromise = new Promise((_, reject) => setTimeout(() => reject(new Error("Timeout conectando a servidor")), 8000));

                Promise.race([authPromise, timeoutPromise]).then((userCred) => {
                    state.user = userCred.user; state.view = 'login'; render();
                    onAuthStateChanged(state.auth, (u) => { if (u) state.user = u; });
                }).catch((e) => {
                    state.firebaseError = e.message; initLocalMode();
                });
            } catch(e) { state.firebaseError = e.message; initLocalMode(); }
        }

